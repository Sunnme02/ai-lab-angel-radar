# 复制为 .env 并填入。LLM key 非必须；无 key 时仍可运行规则管线和模板审查。
OPENALEX_EMAIL=you@example.com
SEMANTIC_SCHOLAR_API_KEY=
GITHUB_TOKEN=

# Optional LLM layer: direction expansion, graph audit, memo writing.
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2
LLM_TIMEOUT=60
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
